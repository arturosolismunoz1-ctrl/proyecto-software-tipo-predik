# ── Desarrollo local ──────────────────────────────────────────────────────────
# El proxy de Vite redirige /api → http://localhost:8000 automáticamente.
# No necesitas VITE_API_URL en desarrollo.
VITE_MAPTILER_KEY=your_maptiler_api_key_here

# ── Producción ────────────────────────────────────────────────────────────────
# Crear frontend/.env.production con estas variables:
# VITE_MAPTILER_KEY=tu_api_key_de_maptiler
# VITE_API_URL=https://tu-backend.onrender.com   ← URL del backend en la nube
