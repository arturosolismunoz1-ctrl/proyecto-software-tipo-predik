# Copia este archivo como .env y llena los valores reales.
# Este archivo (.env.example) SÍ se versiona; .env NUNCA se versiona.

# --- Ambiente ---
ENVIRONMENT=development   # development | qa | production

# --- Base de datos ---
DATABASE_URL=postgresql://admin:CHANGE_ME@localhost:5432/geodata_predik_clone

# --- Seguridad ---
JWT_SECRET=CHANGE_ME
JWT_EXPIRATION_MINUTES=60

# --- Conector INEGI DENUE ---
INEGI_DENUE_API_TOKEN=CHANGE_ME

# --- Conector INEGI Indicadores / BIE ---
INEGI_BIE_API_TOKEN=CHANGE_ME

# --- Conector Google Places (opcional) ---
GOOGLE_PLACES_API_KEY=CHANGE_ME

# --- Cache ---
REDIS_URL=redis://localhost:6379/0

# --- Logging ---
LOG_LEVEL=INFO
