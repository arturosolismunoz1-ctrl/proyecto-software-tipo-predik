# Copia este archivo como .env y llena los valores reales.
# Este archivo (.env.example) SÍ se versiona; .env NUNCA se versiona.

# ── Ambiente ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | qa | production

# ── Base de datos ─────────────────────────────────────────────────────────────
# Formato: postgresql+psycopg2://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql+psycopg2://admin:dev_password_local@localhost:5432/geodata_predik_clone

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# OBLIGATORIO cambiar en QA y Producción. Mínimo 32 caracteres aleatorios.
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev_secret_change_in_production
# Access token expira en minutos (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token expira en días (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Conectores de datos externos ──────────────────────────────────────────────
# INEGI DENUE — token de la API de establecimientos económicos.
# Solicitar en: https://www.inegi.org.mx/servicios/api_denue.html
# Sin token el conector usa 3 registros de demostración.
INEGI_DENUE_TOKEN=

# INEGI BIE (Banco de Información Económica) — indicadores macroeconómicos por estado.
# Obtener token gratuito en: https://www.inegi.org.mx/servicios/api_indicadores.html
# Sin token: el sistema usa datos demo históricos reales automáticamente.
# Con token: descarga ITAEE, desocupación, empleo formal, PEA por los 32 estados.
# ETL: python backend/scripts/etl_bie.py
INEGI_BIE_API_TOKEN=

# Google Places — fuente alternativa de POIs (opcional)
GOOGLE_PLACES_API_KEY=

# ── Rate limiting por organización ────────────────────────────────────────────
# Consultas máximas por mes según plan. Cambiar si se redefinen los planes.
PLAN_STARTER_MONTHLY_LIMIT=50
PLAN_BASIC_MONTHLY_LIMIT=500
PLAN_PLUS_MONTHLY_LIMIT=5000
# Desactivar rate limiting en desarrollo (true | false)
RATE_LIMIT_ENABLED=false

# ── ETL y carga de datos geoespaciales ────────────────────────────────────────
# Directorio donde se colocan los CSVs del Censo 2020 descargados de INEGI.
# Descargar en: https://www.inegi.org.mx/programas/ccpv/2020/#Datos_abiertos
# → "Principales resultados por AGEB y manzana urbana, 2020"
CENSO_DATA_DIR=data/censo_2020

# Directorio con ZIPs del Marco Geoestadístico Nacional 2025.
# Descargar en: https://www.inegi.org.mx/temas/mg/default.html#Descargas
# → Edición 2025 → Por entidad o Nacional (ZIP integrado recomendado)
MGN_DATA_DIR=data/mgn

# ── Cloud / Producción ────────────────────────────────────────────────────────
# Reemplazar en producción (Render, Railway, Fly.io, etc.)
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/db?sslmode=require
# REDIS_URL=redis://default:pass@host:6379
# CORS_ORIGINS=https://tu-dominio.vercel.app,https://www.tu-dominio.com

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Para producción: crear .env.production con VITE_API_URL apuntando al backend
# Ej. VITE_API_URL=https://predik-api.onrender.com
# En desarrollo el proxy de Vite redirige /api → localhost:8000 automáticamente

# ── Scheduler (sincronización nocturna automática) ─────────────────────────────
# Activar el scheduler de APScheduler al iniciar la API (true | false)
SCHEDULER_ENABLED=false
# Hora UTC en que se dispara la sincronización diaria (formato HH:MM)
SCHEDULER_SYNC_TIME=08:00

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
